<Page x:Class="LoyaltySystem.Wpf.Pages.LoyaltyAccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoyaltyAccountsPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Бонусные счета"
                   FontSize="24"
                   FontWeight="Bold"/>

        <DataGrid x:Name="LoyaltyAccountsDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID счета"
                                    Binding="{Binding AccountId}"
                                    Width="90"/>

                <DataGridTextColumn Header="ID клиента"
                                    Binding="{Binding CustomerId}"
                                    Width="90"/>

                <DataGridTextColumn Header="Клиент"
                                    Binding="{Binding CustomerFullName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="130"/>

                <DataGridTextColumn Header="Уровень"
                                    Binding="{Binding LevelName}"
                                    Width="130"/>

                <DataGridTextColumn Header="Баланс бонусов"
                                    Binding="{Binding BonusBalance, StringFormat=N2}"
                                    Width="130"/>

                <DataGridTextColumn Header="Всего потрачено"
                                    Binding="{Binding TotalSpent, StringFormat=N2}"
                                    Width="140"/>

                <DataGridTextColumn Header="Статус счета"
                                    Binding="{Binding AccountStatus}"
                                    Width="120"/>

                <DataGridTextColumn Header="Дата создания"
                                    Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
