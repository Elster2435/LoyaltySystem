<Window x:Class="LoyaltySystem.Wpf.Windows.PromotionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Акция"
        Height="600"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   Text="Акция"
                   FontSize="22"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Название:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="PromotionNameTextBox"
                     Grid.Row="0"
                     Grid.Column="1"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Тип акции:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="PromotionTypeComboBox"
                      Grid.Row="2"
                      Grid.Column="1">
                <ComboBoxItem Content="Общая"/>
                <ComboBoxItem Content="Персональная"/>
                <ComboBoxItem Content="Новый клиент"/>
                <ComboBoxItem Content="День рождения"/>
                <ComboBoxItem Content="Возврат клиента"/>
                <ComboBoxItem Content="Возврат покупки"/>
            </ComboBox>

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Дата начала:"
                       VerticalAlignment="Center"/>

            <DatePicker x:Name="StartDatePicker"
                        Grid.Row="4"
                        Grid.Column="1"/>

            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Text="Дата окончания:"
                       VerticalAlignment="Center"/>

            <DatePicker x:Name="EndDatePicker"
                        Grid.Row="6"
                        Grid.Column="1"/>

            <TextBlock Grid.Row="8"
                       Grid.Column="0"
                       Text="Множитель бонусов:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="BonusMultiplierTextBox"
                     Grid.Row="8"
                     Grid.Column="1"
                     Text="1"/>

            <TextBlock Grid.Row="10"
                       Grid.Column="0"
                       Text="Доп. бонусы:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="ExtraBonusTextBox"
                     Grid.Row="10"
                     Grid.Column="1"
                     Text="0"/>

            <TextBlock Grid.Row="12"
                       Grid.Column="0"
                       Text="Требуемый уровень:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="RequiredLevelComboBox"
                      Grid.Row="12"
                      Grid.Column="1"
                      DisplayMemberPath="LevelName"
                      SelectedValuePath="LevelId"/>

            <TextBlock Grid.Row="14"
                       Grid.Column="0"
                       Text="Описание:"
                       VerticalAlignment="Top"
                       Margin="0,4,0,0"/>

            <TextBox x:Name="DescriptionTextBox"
                     Grid.Row="14"
                     Grid.Column="1"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Сохранить"
                    Width="110"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="110"
                    Height="35"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
