<Page x:Class="LoyaltySystem.Wpf.Pages.CustomerOffersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CustomerOffersPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Персональные предложения"
                   FontSize="24"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Поиск:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     ToolTip="Поиск по клиенту или акции"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Grid.Column="3"
                       Text="Статус:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="StatusFilterComboBox"
                      Grid.Column="4"
                      Height="30"
                      SelectionChanged="StatusFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все статусы"/>
                <ComboBoxItem Content="Назначено"/>
                <ComboBoxItem Content="Использовано"/>
                <ComboBoxItem Content="Истекло"/>
                <ComboBoxItem Content="Отменено"/>
            </ComboBox>

            <TextBlock Grid.Column="6"
                       Text="С:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <DatePicker x:Name="StartDatePicker"
                        Grid.Column="7"
                        Height="30"
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            <TextBlock Grid.Column="9"
                       Text="По:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <DatePicker x:Name="EndDatePicker"
                        Grid.Column="10"
                        Height="30"
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            <Button Grid.Column="12"
                    Content="Сбросить"
                    Width="100"
                    Height="30"
                    Click="ResetFilterButton_Click"/>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">

                <Button Content="Назначить"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="AddButton_Click"/>

                <Button Content="Использовано"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="UseButton_Click"/>

                <Button Content="Истекло"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="ExpireButton_Click"/>

                <Button Content="Отменить"
                        Width="110"
                        Height="35"
                        Click="CancelOfferButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Масштаб таблицы:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Button Content="A-"
                        Width="45"
                        Height="30"
                        Margin="0,0,5,0"
                        Click="DecreaseTableZoomButton_Click"/>

                <TextBlock x:Name="TableZoomTextBlock"
                           Text="100%"
                           Width="50"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>

                <Button Content="A+"
                        Width="45"
                        Height="30"
                        Margin="5,0,5,0"
                        Click="IncreaseTableZoomButton_Click"/>

                <Button Content="100%"
                        Width="55"
                        Height="30"
                        Click="ResetTableZoomButton_Click"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="CustomerOffersDataGrid"
                  Grid.Row="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding OfferId}"
                                    Width="60"/>

                <DataGridTextColumn Header="Клиент"
                                    Binding="{Binding CustomerFullName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Акция"
                                    Binding="{Binding PromotionName}"
                                    Width="250"/>

                <DataGridTextColumn Header="Назначено"
                                    Binding="{Binding AssignedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="150"/>

                <DataGridTextColumn Header="Действует до"
                                    Binding="{Binding ValidUntil, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="150"/>

                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding OfferStatus}"
                                    Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
