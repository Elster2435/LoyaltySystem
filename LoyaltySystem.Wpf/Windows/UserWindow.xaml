<Window x:Class="LoyaltySystem.Wpf.Windows.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь"
        Height="600"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   Text="Пользователь"
                   FontSize="22"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Фамилия:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="LastNameTextBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Имя:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="FirstNameTextBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Отчество:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="MiddleNameTextBox"
                     Grid.Row="4"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Text="Логин:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="LoginTextBox"
                     Grid.Row="6"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"/>

            <TextBlock x:Name="CurrentPasswordTextBlock"
                       Grid.Row="8"
                       Grid.Column="0"
                       Text="Текущий пароль:"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <StackPanel x:Name="CurrentPasswordPanel"
                        Grid.Row="8"
                        Grid.Column="1"
                        Visibility="Collapsed">
                <PasswordBox x:Name="CurrentPasswordBox"
                             Height="30"
                             VerticalContentAlignment="Center"/>

                <TextBlock x:Name="CurrentPasswordHintTextBlock"
                           Text="Заполняется только при смене пароля администратора."
                           TextWrapping="Wrap"
                           Foreground="Gray"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="10"
                       Grid.Column="0"
                       Text="Новый пароль:"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Row="10"
                        Grid.Column="1">
                <PasswordBox x:Name="PasswordBox"
                             Height="30"
                             VerticalContentAlignment="Center"/>

                <TextBlock x:Name="PasswordHintTextBlock"
                           Text="При редактировании оставьте пустым, если пароль менять не нужно."
                           TextWrapping="Wrap"
                           Foreground="Gray"
                           Margin="0,5,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <TextBlock Grid.Row="12"
                       Grid.Column="0"
                       Text="Роль:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="RoleComboBox"
                      Grid.Row="12"
                      Grid.Column="1"
                      Height="30"
                      DisplayMemberPath="DisplayText"
                      SelectedValuePath="RoleId"/>

            <CheckBox x:Name="IsActiveCheckBox"
                      Grid.Row="14"
                      Grid.Column="1"
                      Content="Пользователь активен"
                      IsChecked="True"
                      VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Сохранить"
                    Width="110"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="110"
                    Height="35"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
