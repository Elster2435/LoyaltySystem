<Window x:Class="LoyaltySystem.Wpf.Windows.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент"
        Height="520"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   Text="Клиент"
                   FontSize="22"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center"/>
            <TextBox x:Name="LastNameTextBox" Grid.Row="0" Grid.Column="1"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя:" VerticalAlignment="Center"/>
            <TextBox x:Name="FirstNameTextBox" Grid.Row="2" Grid.Column="1"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center"/>
            <TextBox x:Name="MiddleNameTextBox" Grid.Row="4" Grid.Column="1"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center"/>
            <TextBox x:Name="PhoneTextBox" Grid.Row="6" Grid.Column="1"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Email:" VerticalAlignment="Center"/>
            <TextBox x:Name="EmailTextBox" Grid.Row="8" Grid.Column="1"/>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Дата рождения:" VerticalAlignment="Center"/>
            <DatePicker x:Name="BirthDatePicker" Grid.Row="10" Grid.Column="1"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Text="Пол:" VerticalAlignment="Center"/>
            <ComboBox x:Name="GenderComboBox" Grid.Row="12" Grid.Column="1">
                <ComboBoxItem Content="Мужской"/>
                <ComboBoxItem Content="Женский"/>
            </ComboBox>

            <TextBlock Grid.Row="14" Grid.Column="0" Text="Статус:" VerticalAlignment="Center"/>
            <ComboBox x:Name="StatusComboBox" Grid.Row="14" Grid.Column="1">
                <ComboBoxItem Content="Активный"/>
                <ComboBoxItem Content="Неактивный"/>
                <ComboBoxItem Content="Заблокирован"/>
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Сохранить"
                    Width="110"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="110"
                    Height="35"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
