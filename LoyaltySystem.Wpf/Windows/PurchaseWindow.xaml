<Window x:Class="LoyaltySystem.Wpf.Windows.PurchaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoyaltySystem.Wpf.Windows"
        Title="Добавление покупки"
        Height="520"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Добавление покупки"
                   FontSize="22"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Клиент:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="CustomerComboBox"
                      Grid.Row="0"
                      Grid.Column="1"
                      DisplayMemberPath="DisplayText"
                      SelectedValuePath="CustomerId"
                      SelectionChanged="CustomerComboBox_SelectionChanged"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Сумма покупки:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="TransactionAmountTextBox"
                     Grid.Row="2"
                     Grid.Column="1"/>

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Списать бонусов:"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="BonusUsedTextBox"
                     Grid.Row="4"
                     Grid.Column="1"
                     Text="0"/>

            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Text="Канал:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="TransactionChannelComboBox"
                      Grid.Row="6"
                      Grid.Column="1">
                <ComboBoxItem Content="Оффлайн"/>
                <ComboBoxItem Content="Онлайн"/>
            </ComboBox>

            <TextBlock Grid.Row="8"
                       Grid.Column="0"
                       Text="Тип условия:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="BonusConditionTypeComboBox"
                      Grid.Row="8"
                      Grid.Column="1"
                      SelectionChanged="BonusConditionTypeComboBox_SelectionChanged">
                <ComboBoxItem Content="Без акции / предложения"/>
                <ComboBoxItem Content="Общая акция"/>
                <ComboBoxItem Content="Персональное предложение"/>
            </ComboBox>

            <TextBlock Grid.Row="10"
                       Grid.Column="0"
                       Text="Акция / предложение:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="BonusConditionComboBox"
                      Grid.Row="10"
                      Grid.Column="1"
                      DisplayMemberPath="DisplayText"
                      SelectedValuePath="Id"/>

            <TextBlock Grid.Row="12"
                       Grid.Column="0"
                       Text="Комментарий:"
                       VerticalAlignment="Top"
                       Margin="0,4,0,0"/>

            <TextBox x:Name="CommentTextBox"
                     Grid.Row="12"
                     Grid.Column="1"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="180"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Сохранить"
                    Width="110"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="110"
                    Height="35"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
