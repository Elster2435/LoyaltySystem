<Page x:Class="LoyaltySystem.Wpf.Pages.CustomerActivitiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CustomerActivitiesPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Активность клиентов"
                   FontSize="24"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Поиск:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     ToolTip="Поиск по ФИО клиента или описанию"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Grid.Column="3"
                       Text="Тип:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="ActivityTypeFilterComboBox"
                      Grid.Column="4"
                      Height="30"
                      SelectionChanged="ActivityTypeFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все типы"/>
                <ComboBoxItem Content="Регистрация"/>
                <ComboBoxItem Content="Покупка"/>
                <ComboBoxItem Content="Возврат покупки"/>
                <ComboBoxItem Content="Начисление бонусов"/>
                <ComboBoxItem Content="Списание бонусов"/>
                <ComboBoxItem Content="Получено предложение"/>
                <ComboBoxItem Content="Использовано предложение"/>
                <ComboBoxItem Content="Истекло предложение"/>
                <ComboBoxItem Content="Отменено предложение"/>
                <ComboBoxItem Content="Применена акция"/>
                <ComboBoxItem Content="Изменение профиля"/>
            </ComboBox>

            <TextBlock Grid.Column="6"
                       Text="С:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <DatePicker x:Name="StartDatePicker"
                        Grid.Column="7"
                        Height="30"
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            <TextBlock Grid.Column="9"
                       Text="По:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <DatePicker x:Name="EndDatePicker"
                        Grid.Column="10"
                        Height="30"
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            <Button Grid.Column="12"
                    Content="Сбросить"
                    Width="100"
                    Height="30"
                    Click="ResetFilterButton_Click"/>
        </Grid>

        <DataGrid x:Name="CustomerActivitiesDataGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding ActivityId}"
                                    Width="50"/>

                <DataGridTextColumn Header="ID клиента"
                                    Binding="{Binding CustomerId}"
                                    Width="90"/>

                <DataGridTextColumn Header="Клиент"
                                    Binding="{Binding CustomerFullName}"
                                    Width="300"/>

                <DataGridTextColumn Header="Тип активности"
                                    Binding="{Binding ActivityType}"
                                    Width="180"/>

                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding ActivityDatetime, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="100"/>

                <DataGridTextColumn Header="Описание"
                                    Binding="{Binding Description}"
                                    Width="1000"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
