<Page x:Class="LoyaltySystem.Wpf.Pages.BonusTransactionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BonusTransactionsPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Бонусные операции"
                   FontSize="24"
                   FontWeight="Bold"/>

        <DataGrid x:Name="BonusTransactionsDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding BonusTransactionId}"
                                    Width="70"/>

                <DataGridTextColumn Header="ID счета"
                                    Binding="{Binding AccountId}"
                                    Width="90"/>

                <DataGridTextColumn Header="ID транзакции"
                                    Binding="{Binding TransactionId}"
                                    Width="110"/>

                <DataGridTextColumn Header="Клиент"
                                    Binding="{Binding CustomerFullName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Тип операции"
                                    Binding="{Binding BonusTransactionType}"
                                    Width="130"/>

                <DataGridTextColumn Header="Сумма"
                                    Binding="{Binding Amount, StringFormat=N2}"
                                    Width="110"/>

                <DataGridTextColumn Header="Дата операции"
                                    Binding="{Binding BonusTransactionDatetime, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="160"/>

                <DataGridTextColumn Header="Описание"
                                    Binding="{Binding Description}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
