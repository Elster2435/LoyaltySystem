<Page x:Class="LoyaltySystem.Wpf.Pages.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CustomersPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Клиенты"
                   FontSize="24"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal">

            <Button Content="Добавить"
                    Width="110"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="AddButton_Click"/>

            <Button Content="Изменить"
                    Width="110"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="EditButton_Click"/>

            <Button Content="Деактивировать"
                    Width="130"
                    Height="35"
                    Click="DeleteButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="CustomersDataGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding CustomerId}"
                                    Width="60"/>

                <DataGridTextColumn Header="ФИО"
                                    Binding="{Binding FullName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="130"/>

                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="180"/>

                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding Status}"
                                    Width="110"/>

                <DataGridTextColumn Header="Уровень"
                                    Binding="{Binding LevelName}"
                                    Width="120"/>

                <DataGridTextColumn Header="Бонусы"
                                    Binding="{Binding BonusBalance, StringFormat=N2}"
                                    Width="100"/>

                <DataGridTextColumn Header="Всего потрачено"
                                    Binding="{Binding TotalSpent, StringFormat=N2}"
                                    Width="130"/>

                <DataGridTextColumn Header="Дата регистрации"
                                    Binding="{Binding RegistrationDate, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="160"/>

                <DataGridTextColumn Header="Обновлен"
                                    Binding="{Binding UpdatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
