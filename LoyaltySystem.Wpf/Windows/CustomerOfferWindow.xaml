<Window x:Class="LoyaltySystem.Wpf.Windows.CustomerOfferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Назначение персонального предложения"
        Height="300"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Назначение персонального предложения"
                   FontSize="22"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Клиент:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="CustomerComboBox"
                      Grid.Row="0"
                      Grid.Column="1"
                      DisplayMemberPath="DisplayText"
                      SelectedValuePath="CustomerId"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      StaysOpenOnEdit="True"
                      KeyUp="CustomerComboBox_KeyUp"
                      PreviewTextInput="CustomerComboBox_PreviewTextInput"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Акция:"
                       VerticalAlignment="Center"/>

            <ComboBox x:Name="PromotionComboBox"
                      Grid.Row="2"
                      Grid.Column="1"
                      DisplayMemberPath="DisplayText"
                      SelectedValuePath="PromotionId"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      StaysOpenOnEdit="True"
                      KeyUp="PromotionComboBox_KeyUp"
                      PreviewTextInput="PromotionComboBox_PreviewTextInput"/>

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Действует до:"
                       VerticalAlignment="Center"/>

            <DatePicker x:Name="ValidUntilDatePicker"
                        Grid.Row="4"
                        Grid.Column="1"/>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Сохранить"
                    Width="110"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>

            <Button Content="Отмена"
                    Width="110"
                    Height="35"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
