<Page x:Class="LoyaltySystem.Wpf.Pages.LoyaltyAccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoyaltyAccountsPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Бонусные счета"
                   FontSize="24"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Поиск:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     ToolTip="Поиск по ФИО клиента или телефону"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Grid.Column="3"
                       Text="Уровень:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="LevelFilterComboBox"
                      Grid.Column="4"
                      Height="30"
                      SelectionChanged="LevelFilterComboBox_SelectionChanged"/>

            <TextBlock Grid.Column="6"
                       Text="Статус:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="StatusFilterComboBox"
                      Grid.Column="7"
                      Height="30"
                      SelectionChanged="StatusFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все статусы"/>
                <ComboBoxItem Content="Активный"/>
                <ComboBoxItem Content="Неактивный"/>
                <ComboBoxItem Content="Заблокирован"/>
            </ComboBox>

            <Button Grid.Column="9"
                    Content="Сбросить"
                    Width="100"
                    Height="30"
                    Click="ResetFilterButton_Click"/>
        </Grid>

        <DataGrid x:Name="LoyaltyAccountsDataGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID счета"
                                    Binding="{Binding AccountId}"
                                    Width="90"/>

                <DataGridTextColumn Header="ID клиента"
                                    Binding="{Binding CustomerId}"
                                    Width="90"/>

                <DataGridTextColumn Header="Клиент"
                                    Binding="{Binding CustomerFullName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="130"/>

                <DataGridTextColumn Header="Уровень"
                                    Binding="{Binding LevelName}"
                                    Width="130"/>

                <DataGridTextColumn Header="Баланс бонусов"
                                    Binding="{Binding BonusBalance, StringFormat=N2}"
                                    Width="130"/>

                <DataGridTextColumn Header="Всего потрачено"
                                    Binding="{Binding TotalSpent, StringFormat=N2}"
                                    Width="140"/>

                <DataGridTextColumn Header="Статус счета"
                                    Binding="{Binding AccountStatus}"
                                    Width="120"/>

                <DataGridTextColumn Header="Дата создания"
                                    Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
