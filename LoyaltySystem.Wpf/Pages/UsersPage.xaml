<Page x:Class="LoyaltySystem.Wpf.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UsersPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Пользователи системы"
                   FontSize="24"
                   FontWeight="Bold"/>

        <!-- Поиск и фильтры -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Поиск:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     ToolTip="Поиск по ФИО или логину"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Grid.Column="3"
                       Text="Роль:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="RoleFilterComboBox"
                      Grid.Column="4"
                      Height="30"
                      SelectionChanged="RoleFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все роли"/>
                <ComboBoxItem Content="Администратор"/>
                <ComboBoxItem Content="Менеджер"/>
                <ComboBoxItem Content="Аналитик"/>
            </ComboBox>

            <TextBlock Grid.Column="6"
                       Text="Статус:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="StatusFilterComboBox"
                      Grid.Column="7"
                      Height="30"
                      SelectionChanged="StatusFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все статусы"/>
                <ComboBoxItem Content="Активен"/>
                <ComboBoxItem Content="Отключен"/>
            </ComboBox>

            <Button Grid.Column="9"
                    Content="Сбросить"
                    Width="100"
                    Height="30"
                    Click="ResetFilterButton_Click"/>
        </Grid>

        <!-- Кнопки действий + масштаб таблицы -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">

                <Button Content="Добавить"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="AddButton_Click"/>

                <Button Content="Изменить"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="EditButton_Click"/>

                <Button Content="Активировать"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="ActivateButton_Click"/>

                <Button Content="Отключить"
                        Width="110"
                        Height="35"
                        Click="DeactivateButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Масштаб таблицы:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Button Content="A-"
                        Width="45"
                        Height="30"
                        Margin="0,0,5,0"
                        Click="DecreaseTableZoomButton_Click"/>

                <TextBlock x:Name="TableZoomTextBlock"
                           Text="100%"
                           Width="50"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>

                <Button Content="A+"
                        Width="45"
                        Height="30"
                        Margin="5,0,5,0"
                        Click="IncreaseTableZoomButton_Click"/>

                <Button Content="100%"
                        Width="55"
                        Height="30"
                        Click="ResetTableZoomButton_Click"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="UsersDataGrid"
                  Grid.Row="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding UserId}"
                                    Width="70"/>

                <DataGridTextColumn Header="ФИО"
                                    Binding="{Binding FullName}"
                                    Width="260"/>

                <DataGridTextColumn Header="Логин"
                                    Binding="{Binding Login}"
                                    Width="160"/>

                <DataGridTextColumn Header="Роль"
                                    Binding="{Binding RoleName}"
                                    Width="150"/>

                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding ActivityStatus}"
                                    Width="120"/>

                <DataGridTextColumn Header="Создан"
                                    Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="160"/>

                <DataGridTextColumn Header="Обновлен"
                                    Binding="{Binding UpdatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
