<Page x:Class="LoyaltySystem.Wpf.Pages.TransactionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="TransactionsPage">    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Транзакции"
                   FontSize="24"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="15"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="15"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="15"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="15"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="15"/>

                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Поиск:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     ToolTip="Поиск по ФИО клиента"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Grid.Column="3"
                       Text="Тип:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="TransactionTypeFilterComboBox"
                      Grid.Column="4"
                      Height="30"
                      SelectionChanged="TransactionTypeFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все типы"/>
                <ComboBoxItem Content="Покупка"/>
                <ComboBoxItem Content="Возврат"/>
            </ComboBox>

            <TextBlock Grid.Column="6"
                       Text="Канал:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="ChannelFilterComboBox"
                      Grid.Column="7"
                      Height="30"
                      SelectionChanged="ChannelFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все каналы"/>
                <ComboBoxItem Content="Оффлайн"/>
                <ComboBoxItem Content="Онлайн"/>
            </ComboBox>

            <TextBlock Grid.Column="9"
                       Text="С:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <DatePicker x:Name="StartDatePicker"
                        Grid.Column="10"
                        Height="30"
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            <TextBlock Grid.Column="12"
                       Text="По:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <DatePicker x:Name="EndDatePicker"
                        Grid.Column="13"
                        Height="30"
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            <Button Grid.Column="15"
                    Content="Сбросить"
                    Width="100"
                    Height="30"
                    Click="ResetFilterButton_Click"/>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">

                <Button Content="Добавить покупку"
                        Width="150"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="AddPurchaseButton_Click"/>

                <Button Content="Оформить возврат"
                        Width="150"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="ReturnTransactionButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Масштаб таблицы:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Button Content="A-"
                        Width="45"
                        Height="30"
                        Margin="0,0,5,0"
                        Click="DecreaseTableZoomButton_Click"/>

                <TextBlock x:Name="TableZoomTextBlock"
                           Text="100%"
                           Width="50"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>

                <Button Content="A+"
                        Width="45"
                        Height="30"
                        Margin="5,0,5,0"
                        Click="IncreaseTableZoomButton_Click"/>

                <Button Content="100%"
                        Width="55"
                        Height="30"
                        Click="ResetTableZoomButton_Click"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="TransactionsDataGrid"
                  Grid.Row="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding TransactionId}"
                                    Width="50"/>

                <DataGridTextColumn Header="Тип"
                                    Binding="{Binding TransactionType}"
                                    Width="80"/>

                <DataGridTextColumn Header="Исходная покупка"
                                    Binding="{Binding OriginalTransactionId}"
                                    Width="110"/>

                <DataGridTextColumn Header="Клиент"
                                    Binding="{Binding CustomerFullName}"
                                    Width="250"/>

                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding TransactionDatetime, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="100"/>

                <DataGridTextColumn Header="Сумма"
                                    Binding="{Binding TransactionAmount, StringFormat=N2}"
                                    Width="100"/>

                <DataGridTextColumn Header="Списано бонусов"
                                    Binding="{Binding BonusUsed, StringFormat=N2}"
                                    Width="120"/>

                <DataGridTextColumn Header="Оплачено / возвращено"
                                    Binding="{Binding PaidAmount, StringFormat=N2}"
                                    Width="150"/>

                <DataGridTextColumn Header="Начислено / аннулировано"
                                    Binding="{Binding BonusAccrued, StringFormat=N2}"
                                    Width="170"/>

                <DataGridTextColumn Header="Удержано"
                                    Binding="{Binding BonusCompensationAmount, StringFormat=N2}"
                                    Width="70"/>

                <DataGridTextColumn Header="Канал"
                                    Binding="{Binding TransactionChannel}"
                                    Width="70"/>

                <DataGridTextColumn Header="Акция / предложение"
                                    Binding="{Binding BonusConditionName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Комментарий"
                                    Binding="{Binding Comment}"
                                    Width="400"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
