<Page x:Class="LoyaltySystem.Wpf.Pages.PromotionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PromotionsPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Акции"
                   FontSize="24"
                   FontWeight="Bold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Поиск:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     ToolTip="Поиск по названию или описанию акции"
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Grid.Column="3"
                       Text="Тип:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="PromotionTypeFilterComboBox"
                      Grid.Column="4"
                      Height="30"
                      SelectionChanged="PromotionTypeFilterComboBox_SelectionChanged">
                <ComboBoxItem Content="Все типы"/>
                <ComboBoxItem Content="Общая"/>
                <ComboBoxItem Content="Персональная"/>
                <ComboBoxItem Content="Новый клиент"/>
                <ComboBoxItem Content="День рождения"/>
                <ComboBoxItem Content="Возврат клиента"/>
                <ComboBoxItem Content="Возврат покупки"/>
            </ComboBox>

            <TextBlock Grid.Column="6"
                       Text="Уровень:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="RequiredLevelFilterComboBox"
                      Grid.Column="7"
                      Height="30"
                      SelectionChanged="RequiredLevelFilterComboBox_SelectionChanged"/>

            <Button Grid.Column="9"
                    Content="Сбросить"
                    Width="100"
                    Height="30"
                    Click="ResetFilterButton_Click"/>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">

                <Button x:Name="AddPromotionButton"
                        Content="Добавить"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="AddButton_Click"/>

                <Button x:Name="EditPromotionButton"
                        Content="Изменить"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="EditButton_Click"/>

                <Button x:Name="EnablePromotionButton"
                        Content="Включить"
                        Width="110"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="EnableButton_Click"/>

                <Button x:Name="DisablePromotionButton"
                        Content="Отключить"
                        Width="110"
                        Height="35"
                        Click="DisableButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Масштаб таблицы:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Button Content="A-"
                        Width="45"
                        Height="30"
                        Margin="0,0,5,0"
                        Click="DecreaseTableZoomButton_Click"/>

                <TextBlock x:Name="TableZoomTextBlock"
                           Text="100%"
                           Width="50"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>

                <Button Content="A+"
                        Width="45"
                        Height="30"
                        Margin="5,0,5,0"
                        Click="IncreaseTableZoomButton_Click"/>

                <Button Content="100%"
                        Width="55"
                        Height="30"
                        Click="ResetTableZoomButton_Click"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="PromotionsDataGrid"
                  Grid.Row="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding PromotionId}"
                                    Width="60"/>

                <DataGridTextColumn Header="Название"
                                    Binding="{Binding PromotionName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Тип"
                                    Binding="{Binding PromotionType}"
                                    Width="140"/>

                <DataGridTextColumn Header="Начало"
                                    Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}"
                                    Width="110"/>

                <DataGridTextColumn Header="Окончание"
                                    Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}"
                                    Width="110"/>

                <DataGridTextColumn Header="Множитель"
                                    Binding="{Binding BonusMultiplier, StringFormat=N2}"
                                    Width="100"/>

                <DataGridTextColumn Header="Доп. бонусы"
                                    Binding="{Binding ExtraBonus, StringFormat=N2}"
                                    Width="110"/>

                <DataGridTextColumn Header="Требуемый уровень"
                                    Binding="{Binding RequiredLevelName}"
                                    Width="150"/>

                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding ActivityStatus}"
                                    Width="100"/>

                <DataGridTextColumn Header="Описание"
                                    Binding="{Binding Description}"
                                    Width="600"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
